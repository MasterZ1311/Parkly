// ============================================================
// Parkly — Prisma Database Schema (PostgreSQL)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Users ---
model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  name      String
  email     String?  @unique
  role      UserRole @default(driver)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  vehicles  Vehicle[]
  bookings  Booking[]
  host      Host?
  disputes  Dispute[]

  @@map("users")
}

enum UserRole {
  driver
  host
  admin
}

// --- Vehicles ---
model Vehicle {
  id           String      @id @default(uuid())
  userId       String      @map("user_id")
  licensePlate String      @unique @map("license_plate")
  vehicleType  VehicleType @map("vehicle_type")
  make         String?
  model        String?
  color        String?
  isDefault    Boolean     @default(false) @map("is_default")
  createdAt    DateTime    @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@map("vehicles")
}

enum VehicleType {
  motorcycle
  compact
  sedan
  suv
  van
  truck
}

// --- Hosts ---
model Host {
  id                  String             @id @default(uuid())
  userId              String             @unique @map("user_id")
  businessName        String?            @map("business_name")
  panNumber           String?            @map("pan_number")
  bankAccountNumber   String?            @map("bank_account_number")
  ifscCode            String?            @map("ifsc_code")
  verificationStatus  VerificationStatus @default(pending) @map("verification_status")
  verifiedAt          DateTime?          @map("verified_at")
  totalEarnings       Decimal            @default(0) @map("total_earnings")
  totalPayouts        Decimal            @default(0) @map("total_payouts")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  spaces        ParkingSpace[]
  payouts       Payout[]

  @@map("hosts")
}

enum VerificationStatus {
  pending
  approved
  rejected
}

// --- Parking Spaces ---
model ParkingSpace {
  id             String       @id @default(uuid())
  hostId         String       @map("host_id")
  name           String
  description    String?
  latitude       Decimal      @db.Decimal(10, 7)
  longitude      Decimal      @db.Decimal(10, 7)
  geohash        String       // pre-computed geohash for spatial queries
  address        String
  city           String
  state          String
  pincode        String
  regionId       String       @map("region_id")
  totalCapacity  Int          @map("total_capacity")
  vehicleTypes   VehicleType[]
  evCharging     Boolean      @default(false) @map("ev_charging")
  covered        Boolean      @default(false)
  securityLevel  SecurityLevel @default(none) @map("security_level")
  accessibility  String[]     // array of AccessibilityFeature values
  cctv           Boolean      @default(false)
  lighting       Boolean      @default(false)
  attendant      Boolean      @default(false)
  hourlyRate     Decimal      @map("hourly_rate") @db.Decimal(10, 2)
  currency       String       @default("INR")
  dynamicPricing Boolean      @default(false) @map("dynamic_pricing")
  minBookingHours Int         @default(1) @map("min_booking_hours")
  maxBookingHours Int         @default(24) @map("max_booking_hours")
  photoUrls      String[]     @map("photo_urls")
  status         SpaceStatus  @default(draft)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  host              Host           @relation(fields: [hostId], references: [id])
  availabilitySlots AvailabilitySlot[]
  bookings          Booking[]
  pricingRules      PricingRule[]

  @@index([geohash])
  @@index([city])
  @@index([status])
  @@map("parking_spaces")
}

enum SpaceStatus {
  draft
  pending_verification
  active
  inactive
  suspended
}

enum SecurityLevel {
  none
  basic
  monitored
  staffed
  gated
}

// --- Availability Slots ---
model AvailabilitySlot {
  id         String  @id @default(uuid())
  spaceId    String  @map("space_id")
  dayOfWeek  Int     @map("day_of_week")  // 0-6
  startTime  String  @map("start_time")  // HH:mm
  endTime    String  @map("end_time")    // HH:mm

  space ParkingSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@map("availability_slots")
}

// --- Bookings ---
model Booking {
  id                 String        @id @default(uuid())
  userId             String        @map("user_id")
  spaceId            String        @map("space_id")
  vehicleId          String        @map("vehicle_id")
  hostId             String        @map("host_id")
  type               BookingType
  status             BookingStatus @default(created)
  startTime          DateTime      @map("start_time")
  endTime            DateTime      @map("end_time")
  durationMinutes    Int           @map("duration_minutes")
  recurringFrequency String?       @map("recurring_frequency")
  recurringEndDate   DateTime?     @map("recurring_end_date")
  totalAmount        Decimal       @map("total_amount") @db.Decimal(10, 2)
  currency           String        @default("INR")
  paymentId          String?       @map("payment_id")
  cancellationReason String?       @map("cancellation_reason")
  cancelledAt        DateTime?     @map("cancelled_at")
  completedAt        DateTime?     @map("completed_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  user    User         @relation(fields: [userId], references: [id])
  space   ParkingSpace @relation(fields: [spaceId], references: [id])
  vehicle Vehicle      @relation(fields: [vehicleId], references: [id])
  payment Payment?
  dispute Dispute?

  @@index([userId])
  @@index([spaceId])
  @@index([status])
  @@index([startTime, endTime])
  @@map("bookings")
}


enum BookingType {
  instant
  scheduled
  recurring
}

enum BookingStatus {
  created
  confirmed
  active
  completed
  cancelled
  refunded
}

// --- Payments ---
model Payment {
  id                String        @id @default(uuid())
  bookingId         String        @unique @map("booking_id")
  userId            String        @map("user_id")
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("INR")
  provider          String
  providerPaymentId String?       @map("provider_payment_id")
  providerOrderId   String?       @map("provider_order_id")
  tokenRef          String?       @map("token_ref")  // tokenized ref only, never raw payment data
  status            PaymentStatus @default(pending)
  failureReason     String?       @map("failure_reason")
  refundAmount      Decimal?      @map("refund_amount") @db.Decimal(10, 2)
  refundId          String?       @map("refund_id")
  refundedAt        DateTime?     @map("refunded_at")
  payoutId          String?       @map("payout_id")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("payments")
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

// --- Payouts ---
model Payout {
  id                 String       @id @default(uuid())
  hostId             String       @map("host_id")
  amount             Decimal      @db.Decimal(10, 2)
  platformCommission Decimal      @map("platform_commission") @db.Decimal(10, 2)
  currency           String       @default("INR")
  status             PayoutStatus @default(pending)
  paymentIds         String[]     @map("payment_ids")
  processedAt        DateTime?    @map("processed_at")
  createdAt          DateTime     @default(now()) @map("created_at")

  host Host @relation(fields: [hostId], references: [id])

  @@index([hostId])
  @@map("payouts")
}

enum PayoutStatus {
  pending
  processing
  completed
  failed
}

// --- Pricing Rules ---
model PricingRule {
  id         String   @id @default(uuid())
  spaceId    String?  @map("space_id")  // null = global
  name       String
  multiplier Decimal  @db.Decimal(5, 2)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  space ParkingSpace? @relation(fields: [spaceId], references: [id])

  @@map("pricing_rules")
}

// --- Disputes ---
model Dispute {
  id          String        @id @default(uuid())
  bookingId   String        @unique @map("booking_id")
  raisedBy    String        @map("raised_by")
  disputeType DisputeType   @map("dispute_type")
  description String
  status      DisputeStatus @default(open)
  resolution  String?
  resolvedBy  String?       @map("resolved_by")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id])
  user    User    @relation(fields: [raisedBy], references: [id])

  @@map("disputes")
}

enum DisputeType {
  no_show
  unauthorized_use
  payment_dispute
  other
}

enum DisputeStatus {
  open
  under_review
  resolved
  closed
}

// --- Regions ---
model Region {
  id               String   @id
  name             String
  country          String
  state            String
  city             String
  boundsNorth      Decimal  @map("bounds_north") @db.Decimal(10, 7)
  boundsSouth      Decimal  @map("bounds_south") @db.Decimal(10, 7)
  boundsEast       Decimal  @map("bounds_east") @db.Decimal(10, 7)
  boundsWest       Decimal  @map("bounds_west") @db.Decimal(10, 7)
  geohashPrefixes  String[] @map("geohash_prefixes")
  adjacentRegions  String[] @map("adjacent_regions")
  isActive         Boolean  @default(true) @map("is_active")

  @@map("regions")
}
