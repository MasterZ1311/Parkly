# ============================================================
# Parkly Environment Configuration — EXAMPLE
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- General ---
NODE_ENV=development
LOG_LEVEL=info
CITY_DEFAULT=chennai

# --- API Gateway ---
GATEWAY_PORT=4000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# --- Service Ports (local dev) ---
AUTH_PORT=4001
BOOKING_PORT=4002
PAYMENT_PORT=4003
SEARCH_PORT=4004
PREDICTION_PORT=4005
OCCUPANCY_PORT=4007
PRICING_PORT=4008
NOTIFICATION_PORT=4009
HOST_PORT=4010
ADMIN_PORT=4011

# --- Service URLs (used by gateway) ---
AUTH_URL=http://localhost:4001
BOOKING_URL=http://localhost:4002
PAYMENT_URL=http://localhost:4003
SEARCH_URL=http://localhost:4004
OCCUPANCY_URL=http://localhost:4007
PRICING_URL=http://localhost:4008
HOST_URL=http://localhost:4010
ADMIN_URL=http://localhost:4011

# --- JWT (generate strong secrets in production!) ---
JWT_ACCESS_SECRET=change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=change-me-in-production-another-32-chars
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# --- Database: RDS PostgreSQL ---
DATABASE_URL=postgresql://parkly:password@localhost:5432/parkly
DB_SSL=false

# --- AWS Credentials ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_SESSION_TOKEN=your-session-token  # Only for temporary credentials
AWS_ACCOUNT_ID=your-account-id

# --- DynamoDB ---
# Uncomment for local DynamoDB:
# DYNAMO_ENDPOINT=http://localhost:8000
DYNAMO_TABLE_OTP=parkly-otp
DYNAMO_TABLE_OCCUPANCY=parkly-occupancy
DYNAMO_TABLE_NOTIFICATIONS=parkly-notifications

# --- S3 ---
S3_BUCKET_UPLOADS=parkly-dev-uploads
S3_BUCKET_DATALAKE=parkly-dev-datalake

# --- SNS / SMS ---
SNS_SMS_SENDER_ID=PARKLY

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# --- Payment Gateway ---
PAYMENT_PROVIDER=mock        # mock | razorpay | cashfree
PAYMENT_UPI_VPA=yourname@oksbi
PAYMENT_API_KEY=your-razorpay-key-id
PAYMENT_API_SECRET=your-razorpay-key-secret
PAYMENT_WEBHOOK_SECRET=your-webhook-secret
PLATFORM_COMMISSION_PCT=15

# --- SMS Provider ---
SMS_PROVIDER=sns             # mock | sns | twilio
SMS_API_KEY=

# --- Bedrock (AI) ---
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# --- EventBridge ---
EVENT_BUS_NAME=parkly-event-bus

# --- Push Notifications (FCM) ---
# Firebase Console → Project Settings → Service Accounts → Generate new private key
PUSH_PROVIDER=fcm            # mock | fcm
FCM_PROJECT_ID=your-firebase-project-id
FCM_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FCM_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n

# --- APNS (iOS Push) ---
APNS_KEY_ID=your-apns-key-id
APNS_TEAM_ID=your-apple-team-id
APNS_BUNDLE_ID=in.parkly.app
